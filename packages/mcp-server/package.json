{
  "name": "@kontex/mcp-server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "prebuild": "pnpm --filter @kontex/shared build",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "lint": "echo 'No lint configured for mcp-server'",
    "dev": "tsx src/index.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push"
  },
  "dependencies": {
    "@clerk/backend": "^3.4.14",
    "@google/generative-ai": "^0.24.1",
    "@kontex/shared": "workspace:*",
    "@modelcontextprotocol/sdk": "^1.15.1",
    "@neondatabase/serverless": "^0.10.4",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.36.4",
    "express": "^4.21.0",
    "ws": "^8.18.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/ws": "^8.5.13",
    "drizzle-kit": "^0.28.1",
    "tsx": "^4.19.1",
    "typescript": "^5.6.3",
    "vitest": "^2.1.2"
  }
}
